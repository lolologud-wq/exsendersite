# --- site (web/) ---
SITE_HOST=0.0.0.0
SITE_PORT=3000

# Public URL (for cookies + Crypto Bot webhook)
SITE_PUBLIC_URL=https://exsender.top
# Shared login cookie for inviter.exsender.top and other subdomains
SITE_COOKIE_DOMAIN=.exsender.top
SITE_COOKIE_SECURE=1
SITE_TRUST_PROXY=1

# Inviter web UI (based on https://github.com/exbrute/exinviter)
INVITER_HOSTS=inviter.exsender.top

# Persistent JSON (users, bots, invoices) — survives redeploy
SITE_DATA_DIR=/opt/exsender/data

# Primary admin
SITE_LOGIN=favory
SITE_PASSWORD=change-me-strong-password

# Extra admins — login:password, comma-separated
SITE_ADMINS=operator2:CHANGE_ME_STRONG_PASSWORD

# Random string for signing session cookies (≥32 chars)
SITE_SECRET=please-generate-a-long-random-string-here

SITE_LOG_LEVEL=INFO

# --- Security ---
SITE_CSRF=1
# Rate limit + IP ban (off by default — use Cloudflare/nginx if needed)
SITE_RATE_LIMIT=0
SITE_IP_BAN=0
SITE_MAX_BODY_BYTES=1048576
SITE_RATE_LIMIT_RPM=120
SITE_AUTH_RATE_LIMIT_RPM=15
SITE_ADMIN_RATE_LIMIT_RPM=60
SITE_AUTH_MAX_FAILS=8
SITE_AUTH_BAN_MINUTES=30
SITE_MIN_PASSWORD_LEN=8
SITE_MAX_PASSWORD_LEN=128

# --- Crypto Bot (@CryptoBot → Crypto Pay) ---
CRYPTO_BOT_TOKEN=
CRYPTO_BOT_NETWORK=mainnet
CRYPTO_BOT_ASSET=USDT

# Webhook URL in @CryptoBot:
# https://YOUR_DOMAIN/api/payments/webhook

REFERRAL_BONUS_DAYS=3
REFERRAL_COMMISSION_PCT=15
TRIAL_DAYS=1
TRIAL_MAX_BOTS=1
TRIAL_MAX_ACCOUNTS=2

# Registration verification bot (separate from userbot on VDS)
# Create via @BotFather, then set token + public username
VERIFY_BOT_TOKEN=
VERIFY_BOT_USERNAME=
# Pending registration TTL in seconds (default 15 min)
REGISTER_VERIFY_TTL_SEC=900

# Bot VDS: systemd timer restarts userbot every N hours (0 = off)
USERBOT_RESTART_HOURS=24
