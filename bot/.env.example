# --- Telethon ---
# If API_ID/API_HASH are set — existing .session files keep working.
# TELEGRAM_DEVICE_PROFILE adds Desktop/Android fingerprint for code delivery.
TELEGRAM_CLIENT_PROFILE=custom
TELEGRAM_DEVICE_PROFILE=tdesktop
API_ID=
API_HASH=

# --- Control Telegram bot (optional, can be empty) ---
BOT_TOKEN=
ADMIN_USER_IDS=

# --- HTTP API for the site to talk to ---
BOT_API_ENABLED=1
BOT_API_HOST=0.0.0.0
BOT_API_PORT=8080
# if empty, bot will generate one and save to bot_api_token.txt
BOT_API_TOKEN=

# STOP_SPAM_ON_START=1   # force-stop spam on first boot
